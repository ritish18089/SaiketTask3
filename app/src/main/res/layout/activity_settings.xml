<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/settings" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/llBlockedNumbers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/blocked_numbers" android:textAppearance="?attr/textAppearanceTitleMedium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/manage_blocked_contacts" android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/theme_appearance" android:textAppearance="?attr/textAppearanceTitleMedium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/change_app_theme" android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llSpamDetection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/ai_spam_detection" android:textAppearance="?attr/textAppearanceTitleMedium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/smart_detection_subtitle" android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/about_app" android:textAppearance="?attr/textAppearanceTitleMedium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/version_info_subtitle" android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llHelpFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:paddingVertical="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/help_feedback" android:textAppearance="?attr/textAppearanceTitleMedium" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/help_feedback_subtitle" android:textAppearance="?attr/textAppearanceBodyMedium" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
